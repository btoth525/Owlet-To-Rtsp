# Copy to .env and edit. All values have sane defaults.

# Where Unraid stores appdata for this stack
APPDATA=/mnt/user/appdata/owlet

# Owlet app package name (default is the Owlet Care / Dream app).
# Verify with:  adb -s <ip>:5555 shell pm list packages | grep -i owlet
OWLET_PACKAGE=com.owletcare.owletcare

# Android virtual screen. Keep fixed so crop coordinates stay stable.
SCREEN_SIZE=1280x720
SCREEN_DENSITY=240

# Output stream
FPS=15
BITRATE=4000000          # 4 Mbps

# Capture method: auto | scrcpy | screenrecord
#   auto = try scrcpy (low latency), fall back to screenrecord automatically
CAPTURE_METHOD=auto

# Encoder: auto | h264_nvenc | libx264
#   auto = use NVENC if available, else libx264
ENCODER=auto

# Crop the video region out of the full screen: WIDTH:HEIGHT:X:Y
# Leave blank to send the whole screen first, then measure & set (see README).
CROP=

# Watchdog — keeps the live view awake
TAP_X=640                # center of the 1280x720 screen
TAP_Y=360
WATCHDOG_INTERVAL=120    # seconds; set below the app's idle timeout
WATCHDOG_APP_GUARD=true  # relaunch the app if it loses foreground

# NVIDIA: usually "all". To pin a specific GPU use its UUID (nvidia-smi -L).
NVIDIA_VISIBLE_DEVICES=all
