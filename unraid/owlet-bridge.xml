<?xml version="1.0"?>
<Container version="2">
  <Name>owlet-bridge</Name>
  <Repository>ghcr.io/btoth525/owlet-bridge:latest</Repository>
  <Registry>https://github.com/btoth525/Owlet-To-Rtsp/pkgs/container/owlet-bridge</Registry>
  <Network>owlet-net</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/btoth525/Owlet-To-Rtsp</Support>
  <Project>https://github.com/btoth525/Owlet-To-Rtsp</Project>
  <Overview>go2rtc + adb + scrcpy + ffmpeg(NVENC) + watchdog. Captures the redroid Android display and serves it as RTSP at rtsp://[IP]:8554/owlet for Frigate. go2rtc web UI at http://[IP]:1984.

Deploy AFTER owlet-redroid (same docker network: owlet-net). NVENC needs the Unraid Nvidia-Driver plugin — add "--runtime=nvidia" in Extra Parameters and set NVIDIA_VISIBLE_DEVICES (your GPU UUID from nvidia-smi -L, or "all"). Set ENCODER=libx264 if you don't have/ want NVIDIA.

One-time setup (install + login to the Owlet app, then find crop coords) is documented in the project README.</Overview>
  <Category>Tools: MediaApp:Video</Category>
  <WebUI>http://[IP]:[PORT:1984]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/btoth525/Owlet-To-Rtsp/main/unraid/owlet-bridge.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/AlexxIT/go2rtc/master/assets/logo.png</Icon>
  <ExtraParams>--runtime=nvidia --restart unless-stopped</ExtraParams>
  <PostArgs/>
  <DonateText/>
  <DonateLink/>
  <Config Name="RTSP port (8554)" Target="8554" Default="8554" Mode="tcp" Description="rtsp://[IP]:8554/owlet — point Frigate / VLC here." Type="Port" Display="always" Required="true" Mask="false">8554</Config>
  <Config Name="go2rtc Web UI (1984)" Target="1984" Default="1984" Mode="tcp" Description="go2rtc web UI / API." Type="Port" Display="always" Required="true" Mask="false">1984</Config>
  <Config Name="WebRTC tcp (8555)" Target="8555" Default="8555" Mode="tcp" Description="WebRTC low-latency viewing (tcp)." Type="Port" Display="advanced" Required="false" Mask="false">8555</Config>
  <Config Name="WebRTC udp (8555)" Target="8555" Default="8555" Mode="udp" Description="WebRTC low-latency viewing (udp)." Type="Port" Display="advanced" Required="false" Mask="false">8555</Config>
  <Config Name="ADB_DEVICE" Target="ADB_DEVICE" Default="owlet-redroid:5555" Mode="" Description="Hostname:port of the redroid container on owlet-net." Type="Variable" Display="always" Required="true" Mask="false">owlet-redroid:5555</Config>
  <Config Name="NVIDIA_VISIBLE_DEVICES" Target="NVIDIA_VISIBLE_DEVICES" Default="all" Mode="" Description="GPU UUID from `nvidia-smi -L`, or 'all'." Type="Variable" Display="always" Required="false" Mask="false">all</Config>
  <Config Name="NVIDIA_DRIVER_CAPABILITIES" Target="NVIDIA_DRIVER_CAPABILITIES" Default="all" Mode="" Description="Leave as 'all'." Type="Variable" Display="advanced" Required="false" Mask="false">all</Config>
  <Config Name="OWLET_PACKAGE" Target="OWLET_PACKAGE" Default="com.owletcare.owletcare" Mode="" Description="Owlet app package name." Type="Variable" Display="advanced" Required="false" Mask="false">com.owletcare.owletcare</Config>
  <Config Name="ENCODER" Target="ENCODER" Default="auto" Mode="" Description="auto | h264_nvenc | libx264" Type="Variable" Display="always" Required="false" Mask="false">auto</Config>
  <Config Name="CAPTURE_METHOD" Target="CAPTURE_METHOD" Default="auto" Mode="" Description="auto | scrcpy | screenrecord" Type="Variable" Display="advanced" Required="false" Mask="false">auto</Config>
  <Config Name="CROP" Target="CROP" Default="" Mode="" Description="Crop the video region: WIDTH:HEIGHT:X:Y. Blank = full screen (set after measuring, see README)." Type="Variable" Display="always" Required="false" Mask="false"></Config>
  <Config Name="FPS" Target="FPS" Default="15" Mode="" Description="Output frame rate." Type="Variable" Display="advanced" Required="false" Mask="false">15</Config>
  <Config Name="BITRATE" Target="BITRATE" Default="4000000" Mode="" Description="Output bitrate in bps (4000000 = 4 Mbps)." Type="Variable" Display="advanced" Required="false" Mask="false">4000000</Config>
  <Config Name="SCREEN_SIZE" Target="SCREEN_SIZE" Default="1280x720" Mode="" Description="Android virtual screen size." Type="Variable" Display="advanced" Required="false" Mask="false">1280x720</Config>
  <Config Name="SCREEN_DENSITY" Target="SCREEN_DENSITY" Default="240" Mode="" Description="Android screen density (dpi)." Type="Variable" Display="advanced" Required="false" Mask="false">240</Config>
  <Config Name="TAP_X" Target="TAP_X" Default="640" Mode="" Description="Watchdog tap X (center of video)." Type="Variable" Display="advanced" Required="false" Mask="false">640</Config>
  <Config Name="TAP_Y" Target="TAP_Y" Default="360" Mode="" Description="Watchdog tap Y (center of video)." Type="Variable" Display="advanced" Required="false" Mask="false">360</Config>
  <Config Name="WATCHDOG_INTERVAL" Target="WATCHDOG_INTERVAL" Default="120" Mode="" Description="Seconds between watchdog taps — set below the app idle timeout." Type="Variable" Display="advanced" Required="false" Mask="false">120</Config>
  <Config Name="WATCHDOG_APP_GUARD" Target="WATCHDOG_APP_GUARD" Default="true" Mode="" Description="Relaunch the app if it loses foreground focus." Type="Variable" Display="advanced" Required="false" Mask="false">true</Config>
</Container>
